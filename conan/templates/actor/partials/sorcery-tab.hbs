        <label>Style<input type="text" name="system.sorcery.rituals.{{@index}}.style" value="{{this.style}}"></label>
        <label>PP Cost<input type="text" name="system.sorcery.rituals.{{@index}}.ppCost" value="{{this.ppCost}}"></label>
        <label>Casting Time<input type="text" name="system.sorcery.rituals.{{@index}}.castingTime" value="{{this.castingTime}}"></label>
        <label>Requirements<textarea name="system.sorcery.rituals.{{@index}}.notes">{{this.notes}}</textarea></label>
        <button type="button" class="delete-sorcery-entry" data-group="rituals">Delete</button>
