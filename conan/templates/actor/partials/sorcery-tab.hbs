<section class="panel sorcery-section">
  <h2>Corruption and Sorcerous Consequences</h2>
  <div class="grid two">
    <label>
      Corruption
      <input type="number" name="system.sorcery.corruption.score" value="{{sorcery.corruption.score}}" min="0">
    </label>
    <label>
      Taint / Mark
      <input type="text" name="system.sorcery.corruption.taint" value="{{sorcery.corruption.taint}}">
    </label>
  </div>
  <label>
    Corruption Notes
    <textarea name="system.sorcery.corruption.notes">{{sorcery.corruption.notes}}</textarea>
  </label>
</section>

<section class="panel sorcery-section">
  <h2>Sorcery Notes</h2>
  <textarea name="system.sorcery.notes">{{sorcery.notes}}</textarea>
</section>
