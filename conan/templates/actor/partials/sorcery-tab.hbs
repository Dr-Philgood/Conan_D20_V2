{{!-- Sorcery tab: power points, magic attack, known styles/spells, rituals, components, sacrifices, corruption, and notes. --}}
<section class="panel sorcery-section">
  <h2>{{localize "CONAN.Tabs.Sorcery"}}</h2>
  <div class="sorcery-summary-grid">
    <label>
      Current Power Points
      <input type="number" name="system.sorcery.powerPoints.value" value="{{sorcery.powerPoints.value}}" min="0">
    </label>
    <label>
      Maximum Power Points
      <input type="number" name="system.sorcery.powerPoints.max" value="{{sorcery.powerPoints.max}}" min="0">
    </label>
    <label>
      Temporary Power Points
      <input type="number" name="system.sorcery.powerPoints.temporary" value="{{sorcery.powerPoints.temporary}}" min="0">
    </label>
    <label>
      Power Point Recovery
      <input type="text" name="system.sorcery.powerPoints.recovery" value="{{sorcery.powerPoints.recovery}}">
    </label>
    <button type="button" class="spend-power-point">Spend PP</button>
    <button type="button" class="recover-power-point">Recover PP</button>
    <label>
      Magic Attack Base
      <input type="number" value="{{system.combat.magicAttack.base}}" disabled>
    </label>
    <label>
      Magic Attack Misc
      <input type="number" name="system.combat.magicAttack.misc" value="{{system.combat.magicAttack.misc}}">
    </label>
    <div class="sorcery-total-card">
      <span>Magic Attack Total</span>
      <strong>{{system.combat.magicAttack.total}}</strong>
      <button type="button" class="rollable-magic-attack">Roll</button>
    </div>
  </div>
</section>

<section class="panel sorcery-section">
  <div class="panel-header">
    <h2>Sorcery Styles</h2>
    <button type="button" class="add-sorcery-entry" data-group="styles">Add Style</button>
  </div>
  <div class="sorcery-list">
    {{#each sorcery.styles}}
      <div class="sorcery-row sorcery-style-row" data-sorcery-id="{{this.id}}">
        <input type="hidden" name="system.sorcery.styles.{{@index}}.id" value="{{this.id}}">
        <label>Style<input type="text" name="system.sorcery.styles.{{@index}}.name" value="{{this.name}}"></label>
        <label>Source<input type="text" name="system.sorcery.styles.{{@index}}.source" value="{{this.source}}"></label>
        <label>Notes<textarea name="system.sorcery.styles.{{@index}}.notes">{{this.notes}}</textarea></label>
        <button type="button" class="delete-sorcery-entry" data-group="styles">Delete</button>
      </div>
    {{/each}}
  </div>
</section>

<section class="panel sorcery-section">
  <div class="panel-header">
    <h2>Spells and Advanced Spells</h2>
    <button type="button" class="add-sorcery-entry" data-group="spells">Add Spell</button>
  </div>
  <div class="sorcery-list">
    {{#each sorcery.spells}}
      <div class="sorcery-row sorcery-spell-row" data-sorcery-id="{{this.id}}">
        <input type="hidden" name="system.sorcery.spells.{{@index}}.id" value="{{this.id}}">
        <label>Spell<input type="text" name="system.sorcery.spells.{{@index}}.name" value="{{this.name}}"></label>
        <label>Style<input type="text" name="system.sorcery.spells.{{@index}}.style" value="{{this.style}}"></label>
        <label>PP Cost<input type="text" name="system.sorcery.spells.{{@index}}.ppCost" value="{{this.ppCost}}"></label>
        <label>Casting Time<input type="text" name="system.sorcery.spells.{{@index}}.castingTime" value="{{this.castingTime}}"></label>
        <label>Range<input type="text" name="system.sorcery.spells.{{@index}}.range" value="{{this.range}}"></label>
        <label>Duration<input type="text" name="system.sorcery.spells.{{@index}}.duration" value="{{this.duration}}"></label>
        <label>Components<input type="text" name="system.sorcery.spells.{{@index}}.components" value="{{this.components}}"></label>
        <label>Difficulty<input type="text" name="system.sorcery.spells.{{@index}}.difficulty" value="{{this.difficulty}}"></label>
        <label><input type="checkbox" name="system.sorcery.spells.{{@index}}.prepared" {{#if this.prepared}}checked{{/if}}> Prepared</label>
        <label class="sorcery-notes">Notes<textarea name="system.sorcery.spells.{{@index}}.notes">{{this.notes}}</textarea></label>
        <button type="button" class="delete-sorcery-entry" data-group="spells">Delete</button>
      </div>
    {{/each}}
  </div>
</section>

