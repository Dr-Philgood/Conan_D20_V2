        <label>Limits / Cost<textarea name="system.sorcery.sacrifices.{{@index}}.notes">{{this.notes}}</textarea></label>
        <button type="button" class="delete-sorcery-entry" data-group="sacrifices">Delete</button>
      </div>
    {{/each}}
