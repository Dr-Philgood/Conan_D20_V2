<section class="panel sorcery-section">
  <div class="panel-header">
    <h2>Sacrifices and Power Sources</h2>
    <button type="button" class="add-sorcery-entry" data-group="sacrifices">Add Source</button>
  </div>
  <div class="sorcery-list">
    {{#each sorcery.sacrifices}}
